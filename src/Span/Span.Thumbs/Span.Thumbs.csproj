<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>Span.Thumbs</RootNamespace>
    <AssemblyName>Span.Thumbs</AssemblyName>
    <Platforms>x86;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>false</UseWindowsForms>
    <UseWPF>false</UseWPF>
    <!-- v1.4.5: 이슈 #23 최종 수정 — Span.Thumbs를 self-contained로 전환.
         이전엔 framework-dependent(WindowsAppSDKSelfContained=false)로 빌드되어
         MSIX 설치 후 워커가 .NET 런타임을 못 찾고 즉사 → 무한 spawn 재시도 →
         Process/Pipe 객체가 파이널라이저 큐에 수천 개 적체 → D3D 회수 지연 →
         WinUI composition STATUS_STOWED_EXCEPTION 크래시 (이슈 #23 근본 원인).
         self-contained로 .NET 런타임 포함 → 패키지 크기 +30MB, 격리 기능 정상 작동. -->
    <SelfContained>true</SelfContained>
    <PublishSelfContained>true</PublishSelfContained>
    <!-- WinAppSDK만 deps 공유 (메인과 같은 폴더) — .NET core 런타임은 self-contained -->
    <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
    <!-- Worker는 console 동작 — UI 없음 -->
    <DisableWinExeOutputInference>true</DisableWinExeOutputInference>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260209005" />
    <PackageReference Include="Sentry" Version="6.1.0" />
  </ItemGroup>

</Project>
