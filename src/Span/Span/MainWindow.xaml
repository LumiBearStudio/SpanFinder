<Window
    x:Class="Span.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Span"
    xmlns:models="using:Span.Models"
    xmlns:viewmodels="using:Span.ViewModels"
    xmlns:views="using:Span.Views"
    xmlns:helpers="using:Span.Helpers"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:spancontrols="using:Span.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <!-- FileIconConverter removed: icons are now in ViewModels -->
            <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                          TrueBrush="{StaticResource SpanAccentBrush}"
                                          FalseBrush="Transparent"/>
            <helpers:BoolToThicknessConverter x:Key="BoolToThicknessConverter"
                                              TrueThickness="0,2,1,0"
                                              FalseThickness="0,2,1,0"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TitleBar -->
            <RowDefinition Height="Auto"/> <!-- Unified Bar -->
            <RowDefinition Height="*"/>    <!-- Main Area -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- 1. Title Bar -->
        <Grid x:Name="AppTitleBar" Height="{StaticResource TitleBarHeight}" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0"/> <!-- 캡션 버튼 여백 (코드에서 설정) -->
            </Grid.ColumnDefinitions>
            
            <!-- App Icon & Title -->
            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center" Margin="16,0,16,0" Spacing="8">
                <Image Source="/Assets/Square44x44Logo.png" Height="16" Width="16"/>
                <TextBlock Text="Span" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{StaticResource SpanTextSecondaryBrush}"/>
            </StackPanel>
            
            <!-- Dynamic Tabs -->
            <ScrollViewer x:Name="TabScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Auto" VerticalScrollMode="Disabled">
                <StackPanel x:Name="TabBarContent" Orientation="Horizontal" Spacing="1">
                    <ItemsRepeater x:Name="TabRepeater" ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="1"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TabItem">
                                <Grid Width="200" Height="34" VerticalAlignment="Bottom"
                                      Background="{ThemeResource SpanBgLayer1Brush}" CornerRadius="6,6,0,0"
                                      PointerPressed="OnTabItemPointerPressed"
                                      PointerMoved="OnTabItemPointerMoved"
                                      PointerReleased="OnTabItemPointerReleased"
                                      RightTapped="OnTabRightTapped"
                                      Tag="{x:Bind}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Padding="12,0,0,0">
                                        <!-- Home icon (Segoe Fluent Icons) -->
                                        <FontIcon Glyph="&#xE80F;" FontSize="14"
                                                  Foreground="{ThemeResource SpanAccentBrush}"
                                                  Visibility="{x:Bind IsHomeModeVisible, Mode=OneWay}"/>
                                        <!-- Folder icon (RemixIcons) -->
                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="14"
                                                  Foreground="#FFD54F"
                                                  Visibility="{x:Bind IsNotHomeModeVisible, Mode=OneWay}"/>
                                        <TextBlock Text="{x:Bind Header, Mode=OneWay}"
                                                   FontSize="12" Foreground="{ThemeResource SpanTextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"
                                                   MaxWidth="120"/>
                                    </StackPanel>
                                    <!-- Close button -->
                                    <Button Grid.Column="1" Style="{StaticResource UnifiedButtonStyle}"
                                            Width="24" Height="24" Padding="0" MinWidth="0" MinHeight="0"
                                            Margin="0,0,4,0" VerticalAlignment="Center"
                                            Click="OnTabCloseClick" Tag="{x:Bind}">
                                        <FontIcon Glyph="&#xE711;" FontSize="9"/>
                                    </Button>
                                    <!-- Active indicator -->
                                    <Rectangle Grid.ColumnSpan="2" Height="2" VerticalAlignment="Bottom" Margin="12,0"
                                               Fill="{ThemeResource SpanAccentBrush}"
                                               Visibility="{x:Bind IsActiveVisible, Mode=OneWay}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- New Tab button -->
                    <Button x:Name="NewTabButton" Style="{StaticResource UnifiedButtonStyle}" Width="34" Height="34" VerticalAlignment="Bottom"
                            Margin="2,0,0,0" Click="OnNewTabClick" ToolTipService.ToolTip="New Tab (Ctrl+T)">
                        <FontIcon Glyph="&#xE710;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 2. Unified Bar -->
        <Grid Grid.Row="1" Height="{StaticResource CommandBarHeight}" Background="{ThemeResource SpanBgLayer1Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Nav Buttons -->
                <ColumnDefinition Width="*"/>    <!-- Address Bar -->
                <ColumnDefinition Width="Auto"/> <!-- Commands -->
            </Grid.ColumnDefinitions>

            <!-- Nav Buttons (single mode, hidden in Home) -->
            <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,8,0"
                        Visibility="{x:Bind IsSingleNonHomeVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}">
                <Button x:Name="BackButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="뒤로 (Alt+Left)"
                        IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}" Click="OnGoBackClick"
                        RightTapped="OnBackButtonRightTapped">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                </Button>
                <Button x:Name="ForwardButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="앞으로 (Alt+Right)"
                        IsEnabled="{x:Bind ViewModel.CanGoForward, Mode=OneWay}" Click="OnGoForwardClick"
                        RightTapped="OnForwardButtonRightTapped">
                    <FontIcon Glyph="&#xE72A;" FontSize="14"/>
                </Button>
                <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="위로" Click="OnNavigateUpClick">
                    <FontIcon Glyph="&#xE74A;" FontSize="14"/>
                </Button>
            </StackPanel>

            <!-- Address Bar (single mode, hidden in Home) -->
            <Grid x:Name="AddressBarContainer" Grid.Column="1" Height="32"
                  Background="{ThemeResource SpanBgLayer2Brush}"
                  CornerRadius="4" VerticalAlignment="Center"
                  Padding="4,0"
                  Visibility="{x:Bind IsSingleNonHomeVisible(ViewModel.IsSplitViewEnabled, ViewModel.CurrentViewMode), Mode=OneWay}"
                  Tapped="OnAddressBarContainerClicked">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Breadcrumb with clickable chevron dropdowns -->
                <ScrollViewer x:Name="AddressBreadcrumbScroller" Grid.Column="0"
                              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Auto" VerticalScrollMode="Disabled"
                              SizeChanged="OnBreadcrumbScrollerSizeChanged"
                              ViewChanged="OnBreadcrumbScrollerViewChanged">
                    <ItemsRepeater x:Name="AddressBreadcrumbBar" VerticalAlignment="Center"
                                   SizeChanged="OnBreadcrumbContentSizeChanged">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="0"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:PathSegment">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{x:Bind Name}" Tag="{x:Bind FullPath}"
                                            Click="OnPaneBreadcrumbClick"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="6,4" MinWidth="0" MinHeight="0" CornerRadius="3"
                                            FontSize="12" VerticalAlignment="Center"
                                            Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                                    <Button Tag="{x:Bind FullPath}"
                                            Click="OnBreadcrumbChevronClick"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="2,4" MinWidth="0" MinHeight="0" CornerRadius="2"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind ChevronVisibility}">
                                        <FontIcon Glyph="&#xE76C;" FontSize="8"
                                                  Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                  Margin="0,1,0,0"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
                <!-- Breadcrumb overflow indicator (left fade + ellipsis) -->
                <Border Grid.Column="0" Tag="overflow" HorizontalAlignment="Left"
                        VerticalAlignment="Stretch" Visibility="Collapsed"
                        IsHitTestVisible="False" Padding="4,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="{StaticResource SpanBgLayer2Color}" Offset="0"/>
                            <GradientStop Color="{StaticResource SpanBgLayer2Color}" Offset="0.5"/>
                            <GradientStop Color="#00383838" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="&#x2026;" FontSize="12" VerticalAlignment="Center"
                               Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                </Border>

                <!-- 텍스트 편집 모드 (클릭 시 전환) — AutoSuggestBox for path autocomplete -->
                <AutoSuggestBox x:Name="AddressBarAutoSuggest" Grid.Column="0" Visibility="Collapsed"
                         VerticalAlignment="Center" Height="28" FontSize="12"
                         BorderThickness="0"
                         TextChanged="OnAddressBarTextChanged"
                         SuggestionChosen="OnAddressBarSuggestionChosen"
                         QuerySubmitted="OnAddressBarQuerySubmitted"
                         KeyDown="OnAddressBarAutoSuggestKeyDown"
                         LostFocus="OnAddressBarLostFocus"
                         PlaceholderText="경로 입력..."
                         UpdateTextOnSelect="True"/>

                <!-- 경로 복사 버튼 -->
                <Button x:Name="CopyPathButton" Grid.Column="1"
                        Style="{StaticResource UnifiedButtonStyle}"
                        ToolTipService.ToolTip="경로 복사"
                        Click="OnCopyPathClick"
                        Padding="4,4" MinWidth="0" MinHeight="0"
                        Margin="4,0,0,0">
                    <FontIcon Glyph="&#xE8C8;" FontSize="12"/>
                </Button>
            </Grid>

            <!-- Commands -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" Margin="8,0,0,0">
                <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="새 폴더 (Ctrl+Shift+N)" Click="OnNewFolderClick">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8B7;" FontSize="16"/>
                        <TextBlock Text="새 폴더" FontSize="12"/>
                    </StackPanel>
                </Button>
                <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="잘라내기 (Ctrl+X)" Click="OnCutClick"><FontIcon Glyph="&#xE8C6;"/></Button>
                <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="복사 (Ctrl+C)" Click="OnCopyClick"><FontIcon Glyph="&#xE8C8;"/></Button>
                <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="붙여넣기 (Ctrl+V)" Click="OnPasteClick"><FontIcon Glyph="&#xE77F;"/></Button>
                <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="이름 바꾸기 (F2)" Click="OnRenameClick"><FontIcon Glyph="&#xE70F;"/></Button>
                <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="삭제 (Del)" Click="OnDeleteClick"><FontIcon Glyph="&#xE74D;"/></Button>
                <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>

                <!-- Sort Button with Dropdown -->
                <Button x:Name="SortButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="정렬"
                        Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom" Opening="OnSortMenuOpening">
                            <MenuFlyoutItem x:Name="SortByNameItem" Text="이름" Click="OnSortByName">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C1;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="SortByDateItem" Text="날짜" Click="OnSortByDate">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE787;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="SortBySizeItem" Text="크기" Click="OnSortBySize">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE91B;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="SortByTypeItem" Text="종류" Click="OnSortByType">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8FD;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutItem x:Name="SortAscendingItem" Text="오름차순" Click="OnSortAscending">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74A;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="SortDescendingItem" Text="내림차순" Click="OnSortDescending">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74B;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon x:Name="SortIcon" Glyph="&#xE8CB;" FontSize="14"/>
                        <FontIcon x:Name="SortDirectionIcon" Glyph="&#xE74A;" FontSize="10"/>
                    </StackPanel>
                </Button>

                <!-- View Toggle Button -->
                <Button x:Name="ViewModeButton" Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="보기 전환"
                        Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <!-- Miller Columns -->
                            <MenuFlyoutItem Text="Miller Columns" Click="OnViewModeMillerColumns">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xF0E2;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <!-- Details -->
                            <MenuFlyoutItem Text="Details" Click="OnViewModeDetails">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8EF;"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>

                            <MenuFlyoutSeparator/>

                            <!-- Icon Submenu -->
                            <MenuFlyoutSubItem Text="Icons">
                                <MenuFlyoutSubItem.Icon>
                                    <FontIcon Glyph="&#xE91B;"/>
                                </MenuFlyoutSubItem.Icon>

                                <MenuFlyoutItem Text="Extra Large Icons" Click="OnViewModeIconExtraLarge"/>
                                <MenuFlyoutItem Text="Large Icons" Click="OnViewModeIconLarge"/>
                                <MenuFlyoutItem Text="Medium Icons" Click="OnViewModeIconMedium"/>
                                <MenuFlyoutItem Text="Small Icons" Click="OnViewModeIconSmall"/>
                            </MenuFlyoutSubItem>
                        </MenuFlyout>
                    </Button.Flyout>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8FD;" FontSize="14"/>
                        <FontIcon Glyph="&#xE70D;" FontSize="10"/>
                    </StackPanel>
                </Button>

                <!-- Split View Toggle -->
                <Button x:Name="SplitViewButton" Style="{StaticResource UnifiedButtonStyle}"
                        ToolTipService.ToolTip="Split View (Ctrl+Shift+E)"
                        Click="OnSplitViewToggleClick">
                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="&#xEE8C;" FontSize="16"/>
                </Button>

                <!-- Preview Panel Toggle -->
                <Button x:Name="PreviewToggleButton" Style="{StaticResource UnifiedButtonStyle}"
                        ToolTipService.ToolTip="미리보기 패널 (Ctrl+Shift+P)"
                        Click="OnPreviewToggleClick"
                        Visibility="{x:Bind IsNotSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                    <FontIcon Glyph="&#xE8A0;" FontSize="14"/>
                </Button>

                <Rectangle Width="1" Height="20" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="4,0"/>
                <TextBox x:Name="SearchBox" Width="220" Height="28" FontSize="12"
                         PlaceholderText="Search (kind: size: ext: date:)"
                         ToolTipService.ToolTip="Advanced search syntax:&#x0a;  kind:image  kind:video  kind:document&#x0a;  size:&gt;1MB  size:&lt;100KB  size:large&#x0a;  date:today  date:thisweek  date:&gt;2024-01-01&#x0a;  ext:.pdf  ext:.txt&#x0a;Combine: kind:image size:&gt;1MB"
                         KeyDown="OnSearchBoxKeyDown"/>

            </StackPanel>
        </Grid>

        <!-- 3. Main Area (Sidebar + Content) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/> <!-- Sidebar -->
                <ColumnDefinition Width="*"/>   <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar - Hybrid 3-Section Layout -->
            <Border Grid.Column="0" Background="{ThemeResource SpanBgLayer1Brush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Padding="0,12">

                        <!-- Section 1: 홈 -->
                        <Grid Height="28" Padding="12,0" Background="Transparent"
                              Tapped="OnHomeItemTapped"
                              PointerEntered="OnSidebarItemPointerEntered"
                              PointerExited="OnSidebarItemPointerExited">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE80F;" FontSize="16" Foreground="{ThemeResource SpanAccentBrush}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="홈" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Separator -->
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>

                        <!-- Section 2: 즐겨찾기 (Drop Target) -->
                        <StackPanel AllowDrop="True"
                                    DragOver="OnFavoritesDragOver"
                                    Drop="OnFavoritesDrop">
                        <TextBlock Text="즐겨찾기"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                   FontWeight="SemiBold"
                                   Margin="16,0,16,8"/>

                        <!-- Favorites Tree (expandable sidebar tree with lazy-loaded subfolders) -->
                        <TreeView x:Name="FavoritesTreeView"
                                  SelectionMode="Single"
                                  ItemInvoked="OnFavoritesTreeItemInvoked"
                                  Expanding="OnFavoritesTreeExpanding"
                                  RightTapped="OnFavoritesTreeRightTapped"
                                  CanDragItems="False"
                                  CanReorderItems="False">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="26"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <DataTemplate x:DataType="TreeViewNode">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Content.IconGlyph}"
                                                   FontFamily="/Assets/Fonts/remixicon.ttf#remixicon"
                                                   FontSize="16"
                                                   Foreground="{Binding Content.IconBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Content.Name}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        </StackPanel>

                        <!-- Separator -->
                        <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="12,12"/>

                        <!-- Section 3: 로컬 드라이브 -->
                        <TextBlock Text="로컬 드라이브"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                   FontWeight="SemiBold"
                                   Margin="16,0,16,8"/>

                        <!-- Drives List -->
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DriveItem">
                                    <Grid Height="26"
                                          Padding="12,0,8,0"
                                          Background="Transparent"
                                          Tapped="OnDriveItemTapped"
                                          RightTapped="OnSidebarDriveRightTapped"
                                          PointerEntered="OnSidebarItemPointerEntered"
                                          PointerExited="OnSidebarItemPointerExited">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind IconGlyph}"
                                                   FontFamily="/Assets/Fonts/remixicon.ttf#remixicon"
                                                   FontSize="16"
                                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar bottom bar: Help, Log (left) | Settings (right) -->
                <Grid Grid.Row="1"
                      BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0"
                      Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="0" HorizontalAlignment="Left">
                        <Button x:Name="HelpButton" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="도움말 (F1)" Click="OnHelpClick"
                                Padding="6,4" MinWidth="0" MinHeight="0">
                            <FontIcon Glyph="&#xE897;" FontSize="14"/>
                        </Button>
                        <Button x:Name="LogButton" Style="{StaticResource UnifiedButtonStyle}"
                                ToolTipService.ToolTip="작업 로그" Click="OnLogClick"
                                Padding="6,4" MinWidth="0" MinHeight="0">
                            <FontIcon Glyph="&#xE81C;" FontSize="14"/>
                        </Button>
                    </StackPanel>
                    <Button x:Name="SettingsButton" Style="{StaticResource UnifiedButtonStyle}"
                            ToolTipService.ToolTip="설정" Click="OnSettingsClick"
                            Padding="6,4" MinWidth="0" MinHeight="0"
                            HorizontalAlignment="Right">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                    </Button>
                </Grid>
                </Grid>
            </Border>

            <!-- Content (Split View Container) -->
            <Grid Grid.Column="1" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="SplitterCol" Width="0"/>
                    <ColumnDefinition x:Name="RightPaneCol" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT PANE ===== -->
                <Grid x:Name="LeftPaneContainer" Grid.Column="0" GotFocus="OnLeftPaneGotFocus"
                      PointerPressed="OnLeftPanePointerPressed" Background="Transparent"
                      AllowDrop="True" DragOver="OnPaneDragOver" Drop="OnPaneDrop" DragLeave="OnPaneDragLeave">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Drop overlay (cross-pane visual feedback) -->
                    <Border x:Name="LeftDropOverlay" Grid.RowSpan="2" Opacity="0" IsHitTestVisible="False"
                            Background="{ThemeResource SpanAccentBrush}" CornerRadius="4" Margin="4"/>

                    <!-- Left Pane Path Header (split mode, hidden in Home) -->
                    <Grid Grid.Row="0" x:Name="LeftPathHeader" Height="32"
                          Visibility="{x:Bind IsLeftPaneHeaderVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}"
                          Background="{ThemeResource SpanBgLayer2Brush}"
                          BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1"
                          Tapped="OnLeftPaneHeaderTapped">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>  <!-- Nav buttons -->
                            <ColumnDefinition Width="*"/>     <!-- Breadcrumb -->
                            <ColumnDefinition Width="Auto"/>  <!-- Copy path -->
                        </Grid.ColumnDefinitions>
                        <!-- Active pane accent bar -->
                        <Rectangle Height="2" VerticalAlignment="Top" Grid.ColumnSpan="3"
                                   Fill="{x:Bind LeftPaneAccentBrush(ViewModel.ActivePane), Mode=OneWay}"/>
                        <!-- Nav buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="2,0,0,0">
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="뒤로 (Alt+Left)"
                                    Tag="Left" Click="OnPaneGoBackClick"
                                    RightTapped="OnPaneBackButtonRightTapped"
                                    IsEnabled="{x:Bind ViewModel.CanGoBack, Mode=OneWay}"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72B;" FontSize="11"/>
                            </Button>
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="앞으로 (Alt+Right)"
                                    Tag="Left" Click="OnPaneGoForwardClick"
                                    RightTapped="OnPaneForwardButtonRightTapped"
                                    IsEnabled="{x:Bind ViewModel.CanGoForward, Mode=OneWay}"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72A;" FontSize="11"/>
                            </Button>
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="위로"
                                    Tag="Left" Click="OnPaneNavigateUpClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE74A;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                        <!-- Breadcrumb -->
                        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Auto" VerticalScrollMode="Disabled" Padding="2,6,2,0"
                                      SizeChanged="OnBreadcrumbScrollerSizeChanged"
                                      ViewChanged="OnBreadcrumbScrollerViewChanged">
                            <ItemsRepeater x:Name="LeftPaneBreadcrumbRepeater"
                                           SizeChanged="OnBreadcrumbContentSizeChanged">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="0"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:PathSegment">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="{x:Bind Name}" Tag="{x:Bind FullPath}"
                                                    Click="OnPaneBreadcrumbClick"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="6,2" MinWidth="0" MinHeight="0" CornerRadius="3"
                                                    FontSize="11" VerticalAlignment="Center"
                                                    Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                                            <Button Tag="{x:Bind FullPath}"
                                                    Click="OnBreadcrumbChevronClick"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="2,2" MinWidth="0" MinHeight="0" CornerRadius="2"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind ChevronVisibility}">
                                                <FontIcon Glyph="&#xE76C;" FontSize="8"
                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                          Margin="0,1,0,0"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                        <!-- Breadcrumb overflow indicator -->
                        <Border Grid.Column="1" Tag="overflow" HorizontalAlignment="Left"
                                VerticalAlignment="Stretch" Visibility="Collapsed"
                                IsHitTestVisible="False" Padding="2,0,10,0" Margin="0,6,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="{StaticResource SpanBgLayer2Color}" Offset="0"/>
                                    <GradientStop Color="{StaticResource SpanBgLayer2Color}" Offset="0.5"/>
                                    <GradientStop Color="#00383838" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#x2026;" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                        </Border>
                        <!-- Pane actions: CopyPath | Sort, ViewMode, Preview -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="0,0,2,0">
                            <!-- CopyPath -->
                            <Button Style="{StaticResource UnifiedButtonStyle}"
                                    ToolTipService.ToolTip="경로 복사" Tag="Left" Click="OnPaneCopyPathClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="2,0" VerticalAlignment="Center"/>
                            <!-- Sort -->
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="정렬"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnLeftPaneSortMenuOpening">
                                        <MenuFlyoutItem Text="이름" Click="OnSortByName">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C1;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="날짜" Click="OnSortByDate">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE787;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="크기" Click="OnSortBySize">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="종류" Click="OnSortByType">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="오름차순" Click="OnSortAscending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="내림차순" Click="OnSortDescending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE8CB;" FontSize="11"/>
                            </Button>
                            <!-- ViewMode -->
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="보기 전환"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnLeftPaneViewModeMenuOpening">
                                        <MenuFlyoutItem Text="Miller Columns" Click="OnViewModeMillerColumns">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xF0E2;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Details" Click="OnViewModeDetails">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8EF;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutSubItem Text="Icons">
                                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem Text="Extra Large Icons" Click="OnViewModeIconExtraLarge"/>
                                            <MenuFlyoutItem Text="Large Icons" Click="OnViewModeIconLarge"/>
                                            <MenuFlyoutItem Text="Medium Icons" Click="OnViewModeIconMedium"/>
                                            <MenuFlyoutItem Text="Small Icons" Click="OnViewModeIconSmall"/>
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE8FD;" FontSize="11"/>
                            </Button>
                            <!-- Preview -->
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="미리보기 패널"
                                    Tag="Left" Click="OnPanePreviewToggle"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE8A0;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Left Pane Content -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="LeftPreviewSplitterCol" Width="0"/>
                            <ColumnDefinition x:Name="LeftPreviewCol" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <!-- Explorer Views -->
                        <Grid Grid.Column="0">
                            <!-- Miller Columns Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="MillerTabsHost">
                                <!-- 첫 번째 탭 전용 (XAML 정의) — 추가 탭은 코드에서 동적 생성 -->
                                <ScrollViewer x:Name="MillerScrollViewer"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              >
                                    <StackPanel Orientation="Horizontal">
                                    <ItemsControl x:Name="MillerColumnsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                            <Grid Width="220" MinWidth="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                                        BorderThickness="0,0,0,0"
                                                        Background="{ThemeResource SpanBgMicaBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Rectangle Grid.Row="0" Height="2"
                                                                   Fill="{Binding IsActive, Converter={StaticResource BoolToBrushConverter}}"/>
                                                        <Grid Grid.Row="1" Loaded="OnMillerColumnContentGridLoaded" Unloaded="OnMillerColumnContentGridUnloaded">
                                                            <ListView ItemsSource="{x:Bind Children}" SelectedItem="{x:Bind SelectedChild, Mode=OneWay}"
                                                                      SelectionMode="Extended" IsItemClickEnabled="False"
                                                                      CanDragItems="True" AllowDrop="True"
                                                                      Background="Transparent"
                                                                      ItemContainerStyle="{StaticResource MillerColumnItemStyle}"
                                                                      DragItemsStarting="OnDragItemsStarting"
                                                                      DragOver="OnColumnDragOver" Drop="OnColumnDrop"
                                                                      GotFocus="OnMillerColumnGotFocus"
                                                                      SelectionChanged="OnMillerColumnSelectionChanged"
                                                                      DoubleTapped="OnMillerColumnDoubleTapped"
                                                                      RightTapped="OnMillerColumnEmptyAreaRightTapped">
                                                                <ListView.ItemTemplateSelector>
                                                                    <local:FileSystemItemTemplateSelector>
                                                                        <local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                                                                <Grid Padding="12,4" RightTapped="OnFolderRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Background="{x:Bind PathBackground, Mode=OneWay}"
                                                                                      AllowDrop="True" DragOver="OnFolderItemDragOver" Drop="OnFolderItemDrop" DragLeave="OnFolderItemDragLeave">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="16" Foreground="{x:Bind IconBrush}" Margin="0,0,12,0"/>
                                                                                    <TextBlock Grid.Column="1" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="1" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                    <!-- Item count badge -->
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind ChildCountText, Mode=OneWay}" VerticalAlignment="Center"
                                                                                               FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="4,0,4,0"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <FontIcon Grid.Column="3" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_ChevronRight}" FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.5"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                        <local:FileSystemItemTemplateSelector.FileTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FileViewModel">
                                                                                <Grid Padding="12,4" RightTapped="OnFileRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Background="{x:Bind PathBackground, Mode=OneWay}">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Grid Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{x:Bind IconGlyph}" FontSize="16" Foreground="{x:Bind IconBrush}"
                                                                                                  Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="1" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="1" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FileTemplate>
                                                                    </local:FileSystemItemTemplateSelector>
                                                                </ListView.ItemTemplateSelector>
                                                            </ListView>
                                                            <!-- Loading indicator — visible while folder contents load -->
                                                            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                                                          Width="20" Height="20"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <!-- Empty folder message -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(IsEmpty), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="4" Opacity="0.5">
                                                                <FontIcon Glyph="&#xE8B7;" FontSize="24"
                                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="빈 폴더" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                <!-- Column resize grip -->
                                                <Rectangle Grid.Column="1" Width="4" Fill="Transparent"
                                                           PointerEntered="OnColumnResizeGripPointerEntered"
                                                           PointerExited="OnColumnResizeGripPointerExited"
                                                           PointerPressed="OnColumnResizeGripPointerPressed"
                                                           PointerMoved="OnColumnResizeGripPointerMoved"
                                                           PointerReleased="OnColumnResizeGripPointerReleased"
                                                           DoubleTapped="OnColumnResizeGripDoubleTapped"/>
                                                <!-- Column border line -->
                                                <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Center"
                                                           Fill="{ThemeResource SpanBorderSubtleBrush}" IsHitTestVisible="False"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                    <!-- Inline Preview Column (appears when file is selected in Miller Columns) -->
                                    <Border x:Name="InlinePreviewColumn"
                                            Width="{StaticResource PreviewWidth}"
                                            Background="{ThemeResource SpanBgLayer2Brush}"
                                            BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                            BorderThickness="1,0,0,0"
                                            Visibility="Collapsed">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="InlinePreviewContent" Padding="16" Spacing="12">
                                                <!-- File Icon (large) -->
                                                <Grid HorizontalAlignment="Center" Margin="0,16,0,4">
                                                    <Image x:Name="InlinePreviewThumbnail" Stretch="Uniform"
                                                           MaxWidth="200" MaxHeight="160"
                                                           HorizontalAlignment="Center"
                                                           Visibility="Collapsed"/>
                                                    <FontIcon x:Name="InlinePreviewIcon"
                                                              FontFamily="{StaticResource RemixIcons}"
                                                              FontSize="64" HorizontalAlignment="Center"/>
                                                </Grid>

                                                <!-- File Name -->
                                                <TextBlock x:Name="InlinePreviewFileName"
                                                           TextWrapping="Wrap" TextAlignment="Center"
                                                           FontWeight="SemiBold" FontSize="14"
                                                           MaxLines="3" TextTrimming="CharacterEllipsis"
                                                           HorizontalAlignment="Center"/>

                                                <!-- Image Preview (for image files) -->
                                                <Image x:Name="InlinePreviewImage"
                                                       Stretch="Uniform" MaxHeight="300"
                                                       HorizontalAlignment="Center"
                                                       Visibility="Collapsed"/>

                                                <!-- Text Preview (for text files) -->
                                                <Border x:Name="InlinePreviewTextBorder"
                                                        Background="{ThemeResource SpanBgLayer1Brush}"
                                                        CornerRadius="4" Padding="8" MaxHeight="200"
                                                        Visibility="Collapsed">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Auto"
                                                                  MaxHeight="184">
                                                        <TextBlock x:Name="InlinePreviewText"
                                                                   FontFamily="Consolas" FontSize="11"
                                                                   TextWrapping="Wrap"
                                                                   IsTextSelectionEnabled="True"
                                                                   Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                                                    </ScrollViewer>
                                                </Border>

                                                <!-- Separator -->
                                                <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="0,4"/>

                                                <!-- Metadata -->
                                                <StackPanel x:Name="InlinePreviewMetadata" Spacing="2">
                                                    <!-- File Type -->
                                                    <Grid Height="24">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Type" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="InlinePreviewFileType" Grid.Column="1" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <!-- Size -->
                                                    <Grid Height="24">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Size" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="InlinePreviewFileSize" Grid.Column="1" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <!-- Modified -->
                                                    <Grid Height="24">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Modified" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="InlinePreviewDateModified" Grid.Column="1" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <!-- Created -->
                                                    <Grid Height="24">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Created" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="InlinePreviewDateCreated" Grid.Column="1" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <!-- Dimensions (for images) -->
                                                    <Grid x:Name="InlinePreviewDimensionsRow" Height="24" Visibility="Collapsed">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="72"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Dimensions" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="InlinePreviewDimensions" Grid.Column="1" FontSize="12" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                    </StackPanel>
                            </ScrollViewer>
                            </Grid>

                            <!-- Details View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="DetailsTabsHost" Visibility="Collapsed">
                                <views:DetailsModeView x:Name="DetailsView"/>
                            </Grid>

                            <!-- Icon View Host — 탭별 패널을 Show/Hide로 전환 -->
                            <Grid x:Name="IconTabsHost" Visibility="Collapsed">
                                <views:IconModeView x:Name="IconView"/>
                            </Grid>

                            <!-- Home View (Left only) -->
                            <views:HomeModeView x:Name="HomeView"
                                                Visibility="Collapsed"/>
                        </Grid>

                        <!-- Preview Splitter (Left) -->
                        <controls:GridSplitter Grid.Column="1" Width="2"
                            Background="{ThemeResource SpanBorderSubtleBrush}"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsLeftPreviewEnabled), Mode=OneWay}"/>

                        <!-- Preview Panel (Left) -->
                        <views:PreviewPanelView x:Name="LeftPreviewPanel" Grid.Column="2"
                            MinWidth="200"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsLeftPreviewEnabled), Mode=OneWay}"/>
                    </Grid>
                </Grid>

                <!-- ===== SPLITTER ===== -->
                <controls:GridSplitter Grid.Column="1" Width="2"
                                       Background="{ThemeResource SpanBorderSubtleBrush}"
                                       Visibility="{x:Bind IsSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}"/>

                <!-- ===== RIGHT PANE ===== -->
                <Grid x:Name="RightPaneContainer" Grid.Column="2" GotFocus="OnRightPaneGotFocus"
                      PointerPressed="OnRightPanePointerPressed" Background="Transparent"
                      AllowDrop="True" DragOver="OnPaneDragOver" Drop="OnPaneDrop" DragLeave="OnPaneDragLeave"
                      Visibility="{x:Bind IsSplitVisible(ViewModel.IsSplitViewEnabled), Mode=OneWay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Drop overlay (cross-pane visual feedback) -->
                    <Border x:Name="RightDropOverlay" Grid.RowSpan="2" Opacity="0" IsHitTestVisible="False"
                            Background="{ThemeResource SpanAccentBrush}" CornerRadius="4" Margin="4"/>

                    <!-- Right Pane Path Header -->
                    <Grid Grid.Row="0" x:Name="RightPathHeader" Height="32"
                          Background="{ThemeResource SpanBgLayer2Brush}"
                          BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1"
                          Tapped="OnRightPaneHeaderTapped">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Active pane accent bar -->
                        <Rectangle Height="2" VerticalAlignment="Top" Grid.ColumnSpan="3"
                                   Fill="{x:Bind RightPaneAccentBrush(ViewModel.ActivePane), Mode=OneWay}"/>
                        <!-- Nav buttons -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="2,0,0,0">
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="뒤로 (Alt+Left)"
                                    Tag="Right" Click="OnPaneGoBackClick"
                                    RightTapped="OnPaneBackButtonRightTapped"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72B;" FontSize="11"/>
                            </Button>
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="앞으로 (Alt+Right)"
                                    Tag="Right" Click="OnPaneGoForwardClick"
                                    RightTapped="OnPaneForwardButtonRightTapped"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE72A;" FontSize="11"/>
                            </Button>
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="위로"
                                    Tag="Right" Click="OnPaneNavigateUpClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE74A;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                        <!-- Breadcrumb -->
                        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Auto" VerticalScrollMode="Disabled" Padding="2,6,2,0"
                                      SizeChanged="OnBreadcrumbScrollerSizeChanged"
                                      ViewChanged="OnBreadcrumbScrollerViewChanged">
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.RightExplorer.PathSegments, Mode=OneWay}"
                                           SizeChanged="OnBreadcrumbContentSizeChanged">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="0"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:PathSegment">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="{x:Bind Name}" Tag="{x:Bind FullPath}"
                                                    Click="OnPaneBreadcrumbClick"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="6,2" MinWidth="0" MinHeight="0" CornerRadius="3"
                                                    FontSize="11" VerticalAlignment="Center"
                                                    Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                                            <Button Tag="{x:Bind FullPath}"
                                                    Click="OnBreadcrumbChevronClick"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="2,2" MinWidth="0" MinHeight="0" CornerRadius="2"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind ChevronVisibility}">
                                                <FontIcon Glyph="&#xE76C;" FontSize="8"
                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                          Margin="0,1,0,0"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                        <!-- Breadcrumb overflow indicator -->
                        <Border Grid.Column="1" Tag="overflow" HorizontalAlignment="Left"
                                VerticalAlignment="Stretch" Visibility="Collapsed"
                                IsHitTestVisible="False" Padding="2,0,10,0" Margin="0,6,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="{StaticResource SpanBgLayer2Color}" Offset="0"/>
                                    <GradientStop Color="{StaticResource SpanBgLayer2Color}" Offset="0.5"/>
                                    <GradientStop Color="#00383838" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#x2026;" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                        </Border>
                        <!-- Pane actions: CopyPath | Sort, ViewMode, Preview -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" Margin="0,0,2,0">
                            <!-- CopyPath -->
                            <Button Style="{StaticResource UnifiedButtonStyle}"
                                    ToolTipService.ToolTip="경로 복사" Tag="Right" Click="OnPaneCopyPathClick"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE8C8;" FontSize="11"/>
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="2,0" VerticalAlignment="Center"/>
                            <!-- Sort -->
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="정렬"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnRightPaneSortMenuOpening">
                                        <MenuFlyoutItem Text="이름" Click="OnSortByName">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C1;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="날짜" Click="OnSortByDate">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE787;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="크기" Click="OnSortBySize">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="종류" Click="OnSortByType">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8FD;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="오름차순" Click="OnSortAscending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74A;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="내림차순" Click="OnSortDescending">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74B;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE8CB;" FontSize="11"/>
                            </Button>
                            <!-- ViewMode -->
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="보기 전환"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Bottom" Opening="OnRightPaneViewModeMenuOpening">
                                        <MenuFlyoutItem Text="Miller Columns" Click="OnViewModeMillerColumns">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xF0E2;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Details" Click="OnViewModeDetails">
                                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8EF;"/></MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutSubItem Text="Icons">
                                            <MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE91B;"/></MenuFlyoutSubItem.Icon>
                                            <MenuFlyoutItem Text="Extra Large Icons" Click="OnViewModeIconExtraLarge"/>
                                            <MenuFlyoutItem Text="Large Icons" Click="OnViewModeIconLarge"/>
                                            <MenuFlyoutItem Text="Medium Icons" Click="OnViewModeIconMedium"/>
                                            <MenuFlyoutItem Text="Small Icons" Click="OnViewModeIconSmall"/>
                                        </MenuFlyoutSubItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <FontIcon Glyph="&#xE8FD;" FontSize="11"/>
                            </Button>
                            <!-- Preview -->
                            <Button Style="{StaticResource UnifiedButtonStyle}" ToolTipService.ToolTip="미리보기 패널"
                                    Tag="Right" Click="OnPanePreviewToggle"
                                    Padding="4" MinWidth="0" MinHeight="0" Width="26" Height="26">
                                <FontIcon Glyph="&#xE8A0;" FontSize="11"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Right Pane Content -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="RightPreviewSplitterCol" Width="0"/>
                            <ColumnDefinition x:Name="RightPreviewCol" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <!-- Explorer Views -->
                        <Grid Grid.Column="0">
                            <!-- Miller Columns View (Right) -->
                            <ScrollViewer x:Name="MillerScrollViewerRight"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          Visibility="{x:Bind IsMillerColumnsMode(ViewModel.RightViewMode), Mode=OneWay}">
                                <ItemsControl x:Name="MillerColumnsControlRight" ItemsSource="{x:Bind ViewModel.RightExplorer.Columns, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                            <Grid Width="220" MinWidth="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                                        BorderThickness="0,0,0,0"
                                                        Background="{ThemeResource SpanBgMicaBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Rectangle Grid.Row="0" Height="2"
                                                                   Fill="{Binding IsActive, Converter={StaticResource BoolToBrushConverter}}"/>
                                                        <Grid Grid.Row="1" Loaded="OnMillerColumnContentGridLoaded" Unloaded="OnMillerColumnContentGridUnloaded">
                                                            <ListView ItemsSource="{x:Bind Children}" SelectedItem="{x:Bind SelectedChild, Mode=OneWay}"
                                                                      SelectionMode="Extended" IsItemClickEnabled="False"
                                                                      CanDragItems="True" AllowDrop="True"
                                                                      Background="Transparent"
                                                                      ItemContainerStyle="{StaticResource MillerColumnItemStyle}"
                                                                      DragItemsStarting="OnDragItemsStarting"
                                                                      DragOver="OnColumnDragOver" Drop="OnColumnDrop"
                                                                      GotFocus="OnMillerColumnGotFocus"
                                                                      SelectionChanged="OnMillerColumnSelectionChanged"
                                                                      DoubleTapped="OnMillerColumnDoubleTapped"
                                                                      RightTapped="OnMillerColumnEmptyAreaRightTapped">
                                                                <ListView.ItemTemplateSelector>
                                                                    <local:FileSystemItemTemplateSelector>
                                                                        <local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FolderViewModel">
                                                                                <Grid Padding="12,4" RightTapped="OnFolderRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Background="{x:Bind PathBackground, Mode=OneWay}"
                                                                                      AllowDrop="True" DragOver="OnFolderItemDragOver" Drop="OnFolderItemDrop" DragLeave="OnFolderItemDragLeave">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_Folder}" FontSize="16" Foreground="{x:Bind IconBrush}" Margin="0,0,12,0"/>
                                                                                    <TextBlock Grid.Column="1" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="1" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                    <!-- Item count badge -->
                                                                                    <TextBlock Grid.Column="2" Text="{x:Bind ChildCountText, Mode=OneWay}" VerticalAlignment="Center"
                                                                                               FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="4,0,4,0"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <FontIcon Grid.Column="3" FontFamily="{StaticResource RemixIcons}" Glyph="{StaticResource Icon_ChevronRight}" FontSize="10" Foreground="{ThemeResource SpanTextTertiaryBrush}" Opacity="0.5"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FolderTemplate>
                                                                        <local:FileSystemItemTemplateSelector.FileTemplate>
                                                                            <DataTemplate x:DataType="viewmodels:FileViewModel">
                                                                                <Grid Padding="12,4" RightTapped="OnFileRightTapped"
                                                                                      ToolTipService.ToolTip="{x:Bind TooltipText}"
                                                                                      Background="{x:Bind PathBackground, Mode=OneWay}">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Grid Width="16" Height="16" Margin="0,0,12,0" VerticalAlignment="Center">
                                                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                                                                                        <FontIcon FontFamily="{StaticResource RemixIcons}" Glyph="{x:Bind IconGlyph}" FontSize="16" Foreground="{x:Bind IconBrush}"
                                                                                                  Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                                                                                    </Grid>
                                                                                    <TextBlock Grid.Column="1" Text="{x:Bind TruncatedDisplayName, Mode=OneWay}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                                               Visibility="{x:Bind viewmodels:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>
                                                                                    <TextBox Grid.Column="1" Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                                                                             VerticalAlignment="Center" Padding="2" MinHeight="0" FontSize="13"
                                                                                             LostFocus="OnRenameTextBoxLostFocus" KeyDown="OnRenameTextBoxKeyDown"/>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </local:FileSystemItemTemplateSelector.FileTemplate>
                                                                    </local:FileSystemItemTemplateSelector>
                                                                </ListView.ItemTemplateSelector>
                                                            </ListView>
                                                            <!-- Loading indicator — visible while folder contents load -->
                                                            <ProgressRing IsActive="{x:Bind IsLoading, Mode=OneWay}"
                                                                          Width="20" Height="20"
                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            <!-- Empty folder message -->
                                                            <StackPanel Visibility="{x:Bind viewmodels:FileSystemViewModel.ShowIfTrue(IsEmpty), Mode=OneWay}"
                                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                        Spacing="4" Opacity="0.5">
                                                                <FontIcon Glyph="&#xE8B7;" FontSize="24"
                                                                          Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                          HorizontalAlignment="Center"/>
                                                                <TextBlock Text="빈 폴더" FontSize="12"
                                                                           Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                                                           HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                <!-- Column resize grip -->
                                                <Rectangle Grid.Column="1" Width="4" Fill="Transparent"
                                                           PointerEntered="OnColumnResizeGripPointerEntered"
                                                           PointerExited="OnColumnResizeGripPointerExited"
                                                           PointerPressed="OnColumnResizeGripPointerPressed"
                                                           PointerMoved="OnColumnResizeGripPointerMoved"
                                                           PointerReleased="OnColumnResizeGripPointerReleased"
                                                           DoubleTapped="OnColumnResizeGripDoubleTapped"/>
                                                <!-- Column border line -->
                                                <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Center"
                                                           Fill="{ThemeResource SpanBorderSubtleBrush}" IsHitTestVisible="False"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Details View (Right) -->
                            <views:DetailsModeView x:Name="DetailsViewRight"
                                                   Visibility="{x:Bind IsDetailsMode(ViewModel.RightViewMode), Mode=OneWay}"/>

                            <!-- Icon View (Right) -->
                            <views:IconModeView x:Name="IconViewRight"
                                                Visibility="{x:Bind IsIconMode(ViewModel.RightViewMode), Mode=OneWay}"/>
                        </Grid>

                        <!-- Preview Splitter (Right) -->
                        <controls:GridSplitter Grid.Column="1" Width="2"
                            Background="{ThemeResource SpanBorderSubtleBrush}"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsRightPreviewEnabled), Mode=OneWay}"/>

                        <!-- Preview Panel (Right) -->
                        <views:PreviewPanelView x:Name="RightPreviewPanel" Grid.Column="2"
                            MinWidth="200"
                            Visibility="{x:Bind PreviewVisible(ViewModel.IsRightPreviewEnabled), Mode=OneWay}"/>
                    </Grid>
                </Grid>
            </Grid>

        </Grid>

        <!-- 4. Status Bar -->
        <Grid Grid.Row="3" Height="{StaticResource StatusBarHeight}" Background="{ThemeResource SpanBgMicaBrush}" BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center" Margin="12,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8A5;" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusItemCountText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                </StackPanel>
                <Rectangle Width="1" Height="12" Fill="{ThemeResource SpanBorderSubtleBrush}"
                           Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusSelectionText), Mode=OneWay}"/>
                <TextBlock Text="{x:Bind ViewModel.StatusSelectionText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}"
                           Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusSelectionText), Mode=OneWay}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,0,12,0">
                 <!-- Disk space info -->
                 <StackPanel Orientation="Horizontal" Spacing="6"
                             Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusDiskSpaceText), Mode=OneWay}">
                     <FontIcon Glyph="&#xEDA2;" FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}"/>
                     <TextBlock Text="{x:Bind ViewModel.StatusDiskSpaceText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}" VerticalAlignment="Center"/>
                 </StackPanel>
                 <Rectangle Width="1" Height="12" Fill="{ThemeResource SpanBorderSubtleBrush}"
                            Visibility="{x:Bind helpers:StatusBarHelper.ShowIfNotEmpty(ViewModel.StatusDiskSpaceText), Mode=OneWay}"/>
                 <!-- View mode -->
                 <FontIcon Glyph="&#xE8A9;" FontSize="12" Foreground="{ThemeResource SpanTextSecondaryBrush}"/>
                 <TextBlock Text="{x:Bind ViewModel.StatusViewModeText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SpanTextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- File Operation Progress Panel (floating bottom-right, above content) -->
        <spancontrols:FileOperationProgressControl x:Name="FileOpProgressControl" Grid.Row="2"
                                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                    Canvas.ZIndex="100"
                                                    Margin="0,0,16,8"/>

        <!-- Toast Notification Overlay -->
        <Border x:Name="ToastOverlay" Grid.Row="2"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,16" Padding="16,10"
                Background="{ThemeResource SpanBgLayer1Brush}"
                BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="1"
                CornerRadius="8" Opacity="0" IsHitTestVisible="False"
                RenderTransformOrigin="0.5,1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToastTranslate" Y="20"/>
            </Border.RenderTransform>
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon x:Name="ToastIcon" Glyph="&#xE73E;" FontSize="14"
                          Foreground="{ThemeResource SpanAccentBrush}"/>
                <TextBlock x:Name="ToastText" Text="" FontSize="13"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"
                           VerticalAlignment="Center" MaxWidth="400"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
