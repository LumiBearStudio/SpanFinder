<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Span.Views.OnboardingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <!-- Outer grid: dark background fills rounded corners -->
    <Grid Background="#0C0C0F">
        <!-- Inner border: clips WebView2 with rounded corners -->
        <Border CornerRadius="12" Margin="0" Background="#0C0C0F">
            <controls:WebView2 x:Name="WebContent"
                               DefaultBackgroundColor="#0C0C0F" />
        </Border>
    </Grid>
</Window>
