<UserControl
    x:Class="Span.Views.HomeModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Span.Models"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="RootPanel" Padding="32,24" Spacing="24" MaxWidth="800">

            <!-- Favorites Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="즐겨찾기"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"/>

                <GridView x:Name="FavoritesGridView"
                          ItemsSource="{x:Bind Favorites, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="OnFavoriteClick">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="6"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:FavoriteItem">
                            <Grid Width="120" Height="80"
                                  Padding="12"
                                  CornerRadius="6"
                                  Background="{ThemeResource SpanBgLayer2Brush}"
                                  BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                  BorderThickness="1">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                                              Glyph="{x:Bind IconGlyph}"
                                              Foreground="{x:Bind IconBrush}"
                                              FontSize="24"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Recent Folders Section -->
            <StackPanel Spacing="12">
                <TextBlock Text="최근 폴더"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"/>

                <ListView x:Name="RecentListView"
                          ItemsSource="{x:Bind RecentFolders, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="OnRecentClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:FavoriteItem">
                            <Grid Height="32" Padding="8,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          FontFamily="{StaticResource RemixIcons}"
                                          Glyph="&#xED93;"
                                          FontSize="16"
                                          Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                          Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Name}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Path}"
                                           FontSize="11"
                                           Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="300"
                                           Margin="12,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
