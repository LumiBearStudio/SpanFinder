<UserControl
    x:Class="Span.Views.HomeModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Span.Models"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Background="{ThemeResource SpanBgMicaBrush}">
        <StackPanel x:Name="RootPanel" Padding="32,24" Spacing="24">

            <!-- Section 1: Devices and Drives -->
            <StackPanel Spacing="12">
                <TextBlock x:Name="DevicesHeader"
                           Text="Devices and drives"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"/>

                <GridView x:Name="DrivesGridView"
                          ItemsSource="{x:Bind LocalDrives, Mode=OneWay}"
                          IsItemClickEnabled="True"
                          ItemClick="OnDriveItemClick"
                          SelectionMode="None">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:DriveItem">
                            <Grid Width="220" Height="80"
                                  Padding="14,10"
                                  CornerRadius="6"
                                  Background="{ThemeResource SpanBgLayer2Brush}"
                                  BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                  BorderThickness="1"
                                  RightTapped="OnDriveRightTapped">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Drive Icon -->
                                <FontIcon Grid.Column="0"
                                          FontFamily="{StaticResource RemixIcons}"
                                          Glyph="{x:Bind IconGlyph}"
                                          FontSize="28"
                                          Foreground="{ThemeResource SpanAccentBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>

                                <!-- Drive Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                    <ProgressBar Value="{x:Bind UsagePercent}"
                                                 Maximum="100"
                                                 Height="4"
                                                 CornerRadius="2"/>
                                    <TextBlock Text="{x:Bind SizeDescription}"
                                               FontSize="10"
                                               Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Section 2: Cloud Storage (hidden when empty) -->
            <StackPanel x:Name="CloudSection" Spacing="12"
                        Visibility="{x:Bind HasCloudDrives}">
                <TextBlock x:Name="CloudHeader"
                           Text="Cloud storage"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"/>

                <GridView x:Name="CloudDrivesGridView"
                          ItemsSource="{x:Bind CloudDrivesList, Mode=OneWay}"
                          IsItemClickEnabled="True"
                          ItemClick="OnDriveItemClick"
                          SelectionMode="None">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:DriveItem">
                            <Grid Width="220" Height="80"
                                  Padding="14,10"
                                  CornerRadius="6"
                                  Background="{ThemeResource SpanBgLayer2Brush}"
                                  BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                  BorderThickness="1"
                                  RightTapped="OnDriveRightTapped">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Cloud Icon -->
                                <FontIcon Grid.Column="0"
                                          FontFamily="{StaticResource RemixIcons}"
                                          Glyph="{x:Bind IconGlyph}"
                                          FontSize="28"
                                          Foreground="{ThemeResource SpanAccentBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>

                                <!-- Cloud Drive Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                    <TextBlock Text="{x:Bind SizeDescription}"
                                               FontSize="10"
                                               Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Section 3: Network and Remote (hidden when empty) -->
            <StackPanel x:Name="NetworkSection" Spacing="12"
                        Visibility="{x:Bind HasNetworkDrives}">
                <TextBlock x:Name="NetworkHeader"
                           Text="Network locations"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"/>

                <GridView x:Name="NetworkDrivesGridView"
                          ItemsSource="{x:Bind NetworkDrivesList, Mode=OneWay}"
                          IsItemClickEnabled="True"
                          ItemClick="OnDriveItemClick"
                          SelectionMode="None">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:DriveItem">
                            <Grid Width="220" Height="80"
                                  Padding="14,10"
                                  CornerRadius="6"
                                  Background="{ThemeResource SpanBgLayer2Brush}"
                                  BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                  BorderThickness="1"
                                  RightTapped="OnDriveRightTapped">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Network Icon -->
                                <FontIcon Grid.Column="0"
                                          FontFamily="{StaticResource RemixIcons}"
                                          Glyph="{x:Bind IconGlyph}"
                                          FontSize="28"
                                          Foreground="{ThemeResource SpanTextSecondaryBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>

                                <!-- Network Drive Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                    <TextBlock Text="{x:Bind SizeDescription}"
                                               FontSize="10"
                                               Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Section 4: Favorites -->
            <StackPanel Spacing="12">
                <TextBlock x:Name="FavoritesHeader"
                           Text="Favorites"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource SpanTextPrimaryBrush}"/>

                <GridView x:Name="FavoritesGridView"
                          ItemsSource="{x:Bind Favorites, Mode=OneWay}"
                          IsItemClickEnabled="True"
                          ItemClick="OnFavoriteItemClick"
                          SelectionMode="None">
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,8,8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:FavoriteItem">
                            <Grid Width="120" Height="80"
                                  Padding="12"
                                  CornerRadius="6"
                                  Background="{ThemeResource SpanBgLayer2Brush}"
                                  BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
                                  BorderThickness="1"
                                  RightTapped="OnFavoriteRightTapped">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                    <FontIcon FontFamily="{StaticResource RemixIcons}"
                                              Glyph="{x:Bind IconGlyph}"
                                              Foreground="{x:Bind IconBrush}"
                                              FontSize="24"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="12"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
