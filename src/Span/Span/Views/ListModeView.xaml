<UserControl
    x:Class="Span.Views.ListModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Span.ViewModels"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Tapped="OnRootTapped" RightTapped="OnEmptyAreaRightTapped" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: Size/Date toggles + Column width slider -->
        <Grid Grid.Row="0" Height="26"
              Background="{ThemeResource SpanBgLayer2Brush}"
              BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
              BorderThickness="0,0,0,1"
              Padding="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Size toggle -->
            <ToggleButton x:Name="SizeToggle" Grid.Column="0"
                          IsChecked="True"
                          Content="Size"
                          Click="OnSizeToggleClick"
                          Background="Transparent" BorderThickness="0"
                          Padding="6,2" MinWidth="0" MinHeight="0" Height="22"
                          FontSize="11"
                          Foreground="{ThemeResource SpanTextSecondaryBrush}"/>

            <!-- Date toggle -->
            <ToggleButton x:Name="DateToggle" Grid.Column="1"
                          IsChecked="False"
                          Content="Date"
                          Click="OnDateToggleClick"
                          Background="Transparent" BorderThickness="0"
                          Padding="6,2" MinWidth="0" MinHeight="0" Height="22"
                          FontSize="11" Margin="4,0,0,0"
                          Foreground="{ThemeResource SpanTextSecondaryBrush}"/>

            <!-- Column width label + slider -->
            <TextBlock Grid.Column="3" x:Name="ColumnWidthLabel"
                       Text="250px" FontSize="11" VerticalAlignment="Center"
                       Foreground="{ThemeResource SpanTextTertiaryBrush}"
                       Margin="0,0,8,0"/>

            <Slider x:Name="ColumnWidthSlider" Grid.Column="4"
                    Minimum="150" Maximum="500" Value="250"
                    Width="120" Height="22"
                    ValueChanged="OnColumnWidthChanged"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Items GridView with vertical wrapping -->
        <GridView x:Name="ListGridView" Grid.Row="1"
                  SelectionMode="Extended"
                  CanDragItems="True"
                  DragItemsStarting="OnDragItemsStarting"
                  DoubleTapped="OnItemDoubleClick"
                  SelectionChanged="OnListSelectionChanged"
                  Background="Transparent"
                  Padding="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  ScrollViewer.HorizontalScrollMode="Enabled"
                  ScrollViewer.VerticalScrollMode="Disabled">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Vertical"
                                   x:Name="ListWrapGrid"
                                   ItemWidth="250"
                                   ItemHeight="24"
                                   MaximumRowsOrColumns="0"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="24"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileSystemViewModel">
                    <Grid Height="24" RightTapped="OnItemRightTapped"
                          ToolTipService.ToolTip="{x:Bind TooltipText}"
                          Padding="4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" x:Name="SizeCol"/>
                            <ColumnDefinition Width="Auto" x:Name="DateCol"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon (16px) -->
                        <Grid Grid.Column="0" Width="16" Height="16"
                              HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}" Stretch="UniformToFill"
                                   Visibility="{x:Bind vm:FileSystemViewModel.ShowIfTrue(HasThumbnail), Mode=OneWay}"/>
                            <FontIcon FontFamily="{StaticResource RemixIcons}"
                                      Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                                      Foreground="{x:Bind IconBrush, Mode=OneWay}"
                                      FontSize="16"
                                      Visibility="{x:Bind vm:FileSystemViewModel.ShowIfFalse(HasThumbnail), Mode=OneWay}"/>
                        </Grid>

                        <!-- Name (hidden during rename) -->
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind TruncatedDisplayName, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="12"
                                   Padding="4,0"
                                   Visibility="{x:Bind vm:FileSystemViewModel.NotRenaming(IsRenaming), Mode=OneWay}"/>

                        <!-- Rename TextBox (visible during rename) -->
                        <TextBox Grid.Column="1"
                                 Text="{x:Bind EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{x:Bind IsRenaming, Mode=OneWay}"
                                 VerticalAlignment="Center"
                                 Padding="2" MinHeight="0" FontSize="12"
                                 LostFocus="OnRenameTextBoxLostFocus"
                                 KeyDown="OnRenameTextBoxKeyDown"/>

                        <!-- Size -->
                        <TextBlock Grid.Column="2" x:Name="SizeText"
                                   Text="{x:Bind Size, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                   TextAlignment="Right"
                                   MinWidth="40"
                                   Padding="4,0,4,0"/>

                        <!-- Date (hidden by default) -->
                        <TextBlock Grid.Column="3" x:Name="DateText"
                                   Text="{x:Bind DateModified, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                   Visibility="Collapsed"
                                   MinWidth="60"
                                   Padding="4,0"/>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</UserControl>
