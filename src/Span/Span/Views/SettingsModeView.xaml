<UserControl
    x:Class="Span.Views.SettingsModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Settings Card Style -->
        <Style x:Key="SettingsCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SpanBgLayer1Brush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SettingsSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- Card Label Style -->
        <Style x:Key="SettingsCardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextPrimaryBrush}" />
        </Style>

        <!-- Card Description Style -->
        <Style x:Key="SettingsCardDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- Toggle Row Label Style -->
        <Style x:Key="ToggleRowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Segmented Button Style -->
        <Style x:Key="SegmentedButton" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{ThemeResource SpanTextSecondaryBrush}" />
        </Style>

        <!-- Link Button Style -->
        <Style x:Key="LinkButtonStyle" TargetType="HyperlinkButton">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Card Icon Style -->
        <Style x:Key="CardIconStyle" TargetType="FontIcon">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{ThemeResource SpanAccentBrush}" />
        </Style>

        <!-- Card Icon Container -->
        <Style x:Key="CardIconContainer" TargetType="Border">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource SpanBgLayer2Brush}" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- (ProBadge removed — no Pro tier) -->

        <!-- Shortcut Code Style -->
        <Style x:Key="ShortcutCode" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SpanBgLayer2Brush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with back button -->
        <Grid Grid.Row="0" Padding="20,12,20,8"
              BorderBrush="{ThemeResource SpanBorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackButton" Grid.Column="0" Click="OnBackClick"
                    Background="Transparent" BorderThickness="0"
                    Padding="8,6" CornerRadius="6" VerticalAlignment="Center"
                    ToolTipService.ToolTip="뒤로">
                <FontIcon Glyph="&#xE72B;" FontSize="14"/>
            </Button>
            <TextBlock x:Name="SettingsTitle" Grid.Column="1" Text="설정" FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </Grid>

        <!-- NavigationView (fills remaining space) -->
        <NavigationView x:Name="SettingsNav"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        PaneDisplayMode="Left"
                        OpenPaneLength="180"
                        IsPaneOpen="True"
                        SelectionChanged="SettingsNav_SelectionChanged"
                        SizeChanged="SettingsNav_SizeChanged"
                        Background="Transparent">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavGeneral" Content="일반" Tag="General" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAppearance" Content="모양" Tag="Appearance">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE790;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavBrowsing" Content="탐색" Tag="Browsing">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B0;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavTools" Content="도구" Tag="Tools">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE756;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAdvanced" Content="고급" Tag="Advanced">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem x:Name="NavAbout" Content="정보" Tag="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavOpenSource" Content="오픈소스" Tag="OpenSource">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE943;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <Grid>
                    <!-- ===== General Section ===== -->
                    <ScrollViewer x:Name="GeneralSection" Visibility="Visible">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="GeneralTitle" Text="일반" Style="{StaticResource SettingsSectionTitle}" />

                            <!-- Language -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE774;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="LangLabel" Text="언어 (Language)" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="LangDesc" Text="앱 인터페이스 표시 언어" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                        <ComboBox x:Name="LanguageCombo" Grid.Column="2" SelectedIndex="0" MinWidth="140"
                                                 VerticalAlignment="Center" SelectionChanged="LanguageCombo_SelectionChanged">
                                            <ComboBoxItem x:Name="LangSystem" Content="System Default (권장)" />
                                            <ComboBoxItem Content="English" />
                                            <ComboBoxItem Content="한국어" />
                                            <ComboBoxItem Content="日本語" />
                                        </ComboBox>
                                    </Grid>
                                    <!-- Restart Notice -->
                                    <StackPanel x:Name="LangRestartNotice" Orientation="Horizontal" Spacing="8"
                                                Margin="48,8,0,0" Padding="10,8"
                                                Background="#1AFF8C00" CornerRadius="6"
                                                Visibility="Collapsed">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FF8C00" />
                                        <TextBlock x:Name="LangRestartText" Text="앱을 재시작해야 완벽하게 적용됩니다." FontSize="12"
                                                   Foreground="#FF8C00" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Startup Behavior -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE7A5;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="StartupLabel" Text="시작 시 동작" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="StartupDesc" Text="앱을 실행할 때 보여줄 화면" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <RadioButtons x:Name="StartupRadios" Margin="48,0,0,0">
                                        <RadioButton x:Name="StartupRestore" IsChecked="True">
                                            <StackPanel Spacing="1">
                                                <TextBlock x:Name="RestoreSessionLabel" Text="마지막 세션 복원" FontSize="13" />
                                                <TextBlock x:Name="RestoreSessionDesc" Text="이전에 열어둔 탭과 경로를 유지합니다" FontSize="11"
                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="StartupHome" Content="내 PC (홈) 열기" />
                                        <RadioButton x:Name="StartupFolder">
                                            <StackPanel Spacing="1">
                                                <TextBlock x:Name="OpenFolderLabel" Text="특정 폴더 열기..." FontSize="13" />
                                                <TextBlock x:Name="CustomPathDesc" Text="사용자 지정 경로" FontSize="11"
                                                           Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                    </RadioButtons>
                                </StackPanel>
                            </Border>

                            <!-- Favorites Tree -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE728;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="FavTreeLabel" Text="즐겨찾기 트리뷰" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="FavTreeDesc" Text="즐겨찾기를 트리뷰로 표시 (하위 폴더 탐색 가능)" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="FavoritesTreeToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="False" />
                                </Grid>
                            </Border>

                            <!-- System Tray -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE737;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="SysTrayLabel" Text="시스템 트레이" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="SysTrayDesc" Text="닫기 버튼을 누르면 트레이로 최소화" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="SystemTrayToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="False" />
                                </Grid>
                            </Border>

                            <!-- Remember Window Position -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE737;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="WinPosLabel" Text="창 위치 기억" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="WinPosDesc" Text="앱 종료 시 창 위치와 크기를 저장하여 다음 실행 시 복원" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="WindowPositionToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== Appearance Section ===== -->
                    <ScrollViewer x:Name="AppearanceSection" Visibility="Collapsed">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="AppearanceTitle" Text="모양" Style="{StaticResource SettingsSectionTitle}" />

                            <!-- App Theme -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE790;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="ThemeLabel" Text="앱 테마" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="ThemeDesc" Text="앱의 전체 색상 테마 설정" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                                Background="{ThemeResource SpanBgLayer2Brush}"
                                                CornerRadius="6" Padding="4">
                                        <RadioButton x:Name="ThemeSystem" GroupName="Theme"
                                                     Style="{StaticResource SegmentedButton}" IsChecked="True">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE770;" FontSize="14" />
                                                <TextBlock x:Name="ThemeSystemText" Text="시스템" FontSize="12" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="ThemeLight" GroupName="Theme"
                                                     Style="{StaticResource SegmentedButton}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE706;" FontSize="14" />
                                                <TextBlock x:Name="ThemeLightText" Text="라이트" FontSize="12" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="ThemeDark" GroupName="Theme"
                                                     Style="{StaticResource SegmentedButton}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE708;" FontSize="14" />
                                                <TextBlock x:Name="ThemeDarkText" Text="다크" FontSize="12" />
                                            </StackPanel>
                                        </RadioButton>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Custom Themes (Free) -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE735;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="CustomThemesLabel" Text="커스텀 테마" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="CustomThemesDesc" Text="인기 개발자 컬러 테마" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Margin="48,4,0,0" ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <!-- Dracula -->
                                        <RadioButton x:Name="ThemeDracula" GroupName="Theme" Grid.Column="0" Grid.Row="0"
                                                     HorizontalAlignment="Stretch" MinWidth="0" Padding="0" CornerRadius="8"
                                                     Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="6" Padding="12,10" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#282a36" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#bd93f9" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#f8f8f2" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#ff79c6" />
                                                </StackPanel>
                                                <TextBlock Text="Dracula" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="퍼플 다크 클래식" FontSize="10" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                        <!-- Tokyo Night -->
                                        <RadioButton x:Name="ThemeTokyoNight" GroupName="Theme" Grid.Column="1" Grid.Row="0"
                                                     HorizontalAlignment="Stretch" MinWidth="0" Padding="0" CornerRadius="8"
                                                     Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="6" Padding="12,10" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#1a1b26" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#7aa2f7" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#c0caf5" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#7dcfff" />
                                                </StackPanel>
                                                <TextBlock Text="Tokyo Night" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="네이비 + 시안 포인트" FontSize="10" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                        <!-- Catppuccin Mocha -->
                                        <RadioButton x:Name="ThemeCatppuccin" GroupName="Theme" Grid.Column="0" Grid.Row="1"
                                                     HorizontalAlignment="Stretch" MinWidth="0" Padding="0" CornerRadius="8"
                                                     Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="6" Padding="12,10" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#1e1e2e" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#cba6f7" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#cdd6f4" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#f5c2e7" />
                                                </StackPanel>
                                                <TextBlock Text="Catppuccin" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="따뜻한 파스텔 다크" FontSize="10" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                        <!-- Gruvbox -->
                                        <RadioButton x:Name="ThemeGruvbox" GroupName="Theme" Grid.Column="1" Grid.Row="1"
                                                     HorizontalAlignment="Stretch" MinWidth="0" Padding="0" CornerRadius="8"
                                                     Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="6" Padding="12,10" HorizontalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#282828" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#fe8019" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#ebdbb2" />
                                                    <Border Width="12" Height="12" CornerRadius="6" Background="#fabd2f" />
                                                </StackPanel>
                                                <TextBlock Text="Gruvbox" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="레트로 웜 어스톤" FontSize="10" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Layout Density -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE744;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="DensityLabel" Text="레이아웃 밀도" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="DensityDesc" Text="목록 항목 간격 조절" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Margin="48,0,0,0" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <RadioButton x:Name="DensityCompact" GroupName="Density" Grid.Column="0"
                                                     HorizontalAlignment="Stretch" MinWidth="0" Padding="0" CornerRadius="8"
                                                     Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="6" Padding="12,10" HorizontalAlignment="Center">
                                                <StackPanel Spacing="3" HorizontalAlignment="Center">
                                                    <Border Width="50" Height="3" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="3" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="3" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="3" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="3" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                </StackPanel>
                                                <TextBlock Text="Compact" FontSize="11" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="DensityComfortable" GroupName="Density" Grid.Column="1"
                                                     HorizontalAlignment="Stretch" MinWidth="0" Padding="0" CornerRadius="8"
                                                     IsChecked="True" Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="6" Padding="12,10" HorizontalAlignment="Center">
                                                <StackPanel Spacing="5" HorizontalAlignment="Center">
                                                    <Border Width="50" Height="5" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="5" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="5" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="5" CornerRadius="2" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                </StackPanel>
                                                <TextBlock Text="Comfortable" FontSize="11" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="DensitySpacious" GroupName="Density" Grid.Column="2"
                                                     HorizontalAlignment="Stretch" MinWidth="0" Padding="0" CornerRadius="8"
                                                     Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="6" Padding="12,10" HorizontalAlignment="Center">
                                                <StackPanel Spacing="7" HorizontalAlignment="Center">
                                                    <Border Width="50" Height="7" CornerRadius="3" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="7" CornerRadius="3" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                    <Border Width="50" Height="7" CornerRadius="3" Background="{ThemeResource SpanTextSecondaryBrush}" Opacity="0.5" />
                                                </StackPanel>
                                                <TextBlock Text="Spacious" FontSize="11" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                            </StackPanel>
                                        </RadioButton>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Icon Pack -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
