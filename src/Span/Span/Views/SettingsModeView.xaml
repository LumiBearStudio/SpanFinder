                                            </Border>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ShowHiddenToggle" Grid.Column="1" IsOn="False" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="48,0,0,0" />
                                    <Grid Margin="48,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="ShowExtLabel" Grid.Column="0" Text="파일 확장자 표시" Style="{StaticResource ToggleRowLabel}" />
                                        <ToggleSwitch x:Name="ShowExtensionsToggle" Grid.Column="1" IsOn="True" />
                                    </Grid>
                                    <Rectangle Height="1" Fill="{ThemeResource SpanBorderSubtleBrush}" Margin="48,0,0,0" />
                                    <Grid Margin="48,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="CheckboxLabel" Grid.Column="0" Text="체크박스 사용하여 항목 선택" Style="{StaticResource ToggleRowLabel}" />
                                        <ToggleSwitch x:Name="CheckboxToggle" Grid.Column="1" IsOn="False" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Miller Column Behavior -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE80A;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="MillerLabel" Text="밀러 컬럼 동작" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="MillerDesc" Text="폴더 열기 방식" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ComboBox x:Name="MillerClickCombo" Grid.Column="2" SelectedIndex="0" MinWidth="140" VerticalAlignment="Center">
                                        <ComboBoxItem x:Name="SingleClickItem" Content="한 번 클릭" />
                                        <ComboBoxItem x:Name="DoubleClickItem" Content="더블 클릭" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Image Thumbnails -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE8B9;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="ThumbnailLabel" Text="이미지 미리보기 (썸네일)" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="ThumbnailDesc" Text="성능을 위해 네트워크 드라이브에서는 썸네일을 끕니다" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ThumbnailToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" />
                                </Grid>
                            </Border>

                            <!-- Quick Look -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE773;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="QuickLookLabel" Text="Quick Look (빠른 미리보기)" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="QuickLookDesc" Text="Space 키로 파일을 빠르게 미리봅니다" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="QuickLookToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" />
                                </Grid>
                            </Border>

                            <!-- Delete Confirmation -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE74D;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="DeleteConfirmLabel" Text="삭제 확인 대화상자" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="DeleteConfirmDesc" Text="파일 삭제 전 확인을 요청합니다" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ConfirmDeleteToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" />
                                </Grid>
                            </Border>

                            <!-- Undo History -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE81C;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="UndoLabel" Text="실행 취소 (Undo) 기록 보관" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="UndoDesc" Text="보관할 실행 취소 작업 수 (0 = 비활성)" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ComboBox x:Name="UndoHistoryCombo" Grid.Column="2" SelectedIndex="2" MinWidth="100" VerticalAlignment="Center">
                                        <ComboBoxItem x:Name="Undo10" Content="10개" />
                                        <ComboBoxItem x:Name="Undo20" Content="20개" />
                                        <ComboBoxItem x:Name="Undo50" Content="50개" />
                                        <ComboBoxItem x:Name="Undo100" Content="100개" />
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== Tools Section ===== -->
                    <ScrollViewer x:Name="ToolsSection" Visibility="Collapsed">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="ToolsTitle" Text="도구" Style="{StaticResource SettingsSectionTitle}" />

                            <!-- Windows Shell Extras -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE8B7;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="ShellExtLabel" Text="Windows 셸 확장 메뉴" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="ShellExtDesc" Text="우클릭 메뉴에 공유, 보내기, 라이브러리 포함, 시작 화면 고정 등 표시" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ShellExtrasToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="False" />
                                </Grid>
                            </Border>

                            <!-- Copilot Menu Toggle -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE945;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="CopilotLabel" Text="Copilot 메뉴" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="CopilotDesc" Text="우클릭 메뉴에 Microsoft Copilot 관련 항목 표시" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="CopilotMenuToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="False" />
                                </Grid>
                            </Border>

                            <!-- Context Menu Integration -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE712;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="CtxMenuLabel" Text="컨텍스트 메뉴" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="CtxMenuDesc" Text="윈도우 우클릭 메뉴에 'Open in Span' 추가" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ContextMenuToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="True" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== Advanced Section ===== -->
                    <ScrollViewer x:Name="AdvancedSection" Visibility="Collapsed">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="AdvancedTitle" Text="고급" Style="{StaticResource SettingsSectionTitle}" />

                            <!-- Default Terminal App -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE756;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="TerminalLabel" Text="기본 터미널 앱" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="TerminalDesc" Text="Ctrl+` 또는 우클릭 '터미널 열기' 시 실행" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ComboBox x:Name="TerminalCombo" Grid.Column="2" SelectedIndex="0" MinWidth="140" VerticalAlignment="Center">
                                        <ComboBoxItem Content="Windows Terminal" />
                                        <ComboBoxItem Content="PowerShell" />
                                        <ComboBoxItem Content="CMD" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <!-- Developer Context Menu -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE943;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="DevMenuLabel" Text="개발자 컨텍스트 메뉴" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="DevMenuDesc" Text="우클릭 메뉴에 Git, Visual Studio, VS Code 등 개발 도구 항목 표시" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="DeveloperMenuToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="False" />
                                </Grid>
                            </Border>

                            <!-- Git Integration Toggle -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xE8AD;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="GitIntegrationLabel" Text="Git 상태 통합" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="GitIntegrationDesc" Text="파일 아이콘에 Git 상태 뱃지(M/A/?/!)와 미리보기 패널에 커밋 이력을 표시합니다" Style="{StaticResource SettingsCardDesc}" />
                                        <TextBlock x:Name="GitVersionLabel" Text="" FontSize="11"
                                                   Foreground="{ThemeResource SpanTextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="GitIntegrationToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="False" />
                                </Grid>
                            </Border>

                            <!-- Hex Viewer Toggle -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardIconContainer}">
                                        <FontIcon Glyph="&#xEA37;" Style="{StaticResource CardIconStyle}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock x:Name="HexPreviewLabel" Text="Hex 뷰어 미리보기" Style="{StaticResource SettingsCardLabel}" />
                                        <TextBlock x:Name="HexPreviewDesc" Text="바이너리 파일(.dll, .exe 등) 선택 시 미리보기 패널에 Hex 덤프를 표시합니다" Style="{StaticResource SettingsCardDesc}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="HexPreviewToggle" Grid.Column="2" VerticalAlignment="Center" IsOn="False" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== About Section ===== -->
                    <ScrollViewer x:Name="AboutSection" Visibility="Collapsed">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="AboutTitle" Text="정보" Style="{StaticResource SettingsSectionTitle}" />

                            <!-- App Info Hero -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE80F;" FontSize="40" Foreground="{ThemeResource SpanAccentBrush}" />
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="SPAN Finder" FontSize="22" FontWeight="Bold" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            <TextBlock Text="v1.0.1 (Build 20260226)" FontSize="12" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Button x:Name="UpdateButton" Grid.Column="1" VerticalAlignment="Center"
                                            Click="CheckForUpdates_Click" Padding="12,8" CornerRadius="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon x:Name="UpdateIcon" Glyph="&#xE72C;" FontSize="14" />
                                            <TextBlock x:Name="UpdateText" Text="업데이트 확인" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Links -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="4">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE71B;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <TextBlock x:Name="LinksLabel" Text="관련 링크" Style="{StaticResource SettingsCardLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <HyperlinkButton Style="{StaticResource LinkButtonStyle}" Margin="48,0,0,0" NavigateUri="https://github.com/kangjinkyu/Span">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE774;" FontSize="14" />
                                            <TextBlock x:Name="GitHubText" Text="GitHub 저장소" />
                                            <FontIcon Glyph="&#xE8A7;" FontSize="10" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                        </StackPanel>
                                    </HyperlinkButton>
                                    <HyperlinkButton Style="{StaticResource LinkButtonStyle}" Margin="48,0,0,0" NavigateUri="https://github.com/kangjinkyu/Span/issues">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xEBE8;" FontSize="14" />
                                            <TextBlock x:Name="BugReportText" Text="버그 제보" />
                                            <FontIcon Glyph="&#xE8A7;" FontSize="10" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                        </StackPanel>
                                    </HyperlinkButton>
                                    <HyperlinkButton Style="{StaticResource LinkButtonStyle}" Margin="48,0,0,0" NavigateUri="https://github.com/kangjinkyu/Span/blob/main/PRIVACY.md">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xEA18;" FontSize="14" />
                                            <TextBlock x:Name="PrivacyText" Text="개인정보 처리방침" />
                                            <FontIcon Glyph="&#xE8A7;" FontSize="10" Foreground="{ThemeResource SpanTextSecondaryBrush}" />
                                        </StackPanel>
                                    </HyperlinkButton>
                                </StackPanel>
                            </Border>

                            <!-- Buy me a coffee -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xED54;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="CoffeeLabel" Text="Buy me a coffee" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="CoffeeDesc" Text="Span이 마음에 드셨다면, 커피 한 잔으로 응원해 주세요!" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Margin="48,0,0,0" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" HorizontalAlignment="Stretch" Padding="8,12" CornerRadius="8" Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <TextBlock Text="&#x2615;" FontSize="20" HorizontalAlignment="Center" />
                                                <TextBlock Text="$3" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" HorizontalAlignment="Stretch" Padding="8,12" CornerRadius="8" Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <TextBlock Text="&#x1F370;" FontSize="20" HorizontalAlignment="Center" />
                                                <TextBlock Text="$5" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" HorizontalAlignment="Stretch" Padding="8,12" CornerRadius="8" Background="{ThemeResource SpanBgLayer2Brush}">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <TextBlock Text="&#x1F355;" FontSize="20" HorizontalAlignment="Center" />
                                                <TextBlock Text="$10" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="3" HorizontalAlignment="Stretch" Padding="8,12" CornerRadius="8" Background="{ThemeResource SpanAccentBrush}">
                                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                                <TextBlock Text="&#x1F680;" FontSize="20" HorizontalAlignment="Center" />
                                                <TextBlock Text="$50" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="White" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Copyright -->
                            <TextBlock x:Name="CopyrightLabel"
                                       Text="© 2026 LumiBear Studio. All rights reserved."
                                       FontSize="12" Foreground="{ThemeResource SpanTextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,20,0,8" />
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ===== Open Source Section ===== -->
                    <ScrollViewer x:Name="OpenSourceSection" Visibility="Collapsed">
                        <StackPanel Padding="20" Spacing="0">
                            <TextBlock x:Name="OpenSourceTitle" Text="오픈소스 라이선스" Style="{StaticResource SettingsSectionTitle}" />

                            <TextBlock x:Name="OpenSourceDesc" Text="Span은 다음 오픈소스 프로젝트의 도움으로 만들어졌습니다."
                                       Style="{StaticResource SettingsCardDesc}" Margin="0,0,0,12" />

                            <!-- NuGet Packages -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE74C;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <TextBlock Text="라이브러리" Style="{StaticResource SettingsCardLabel}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Border Background="{ThemeResource SpanBgLayer2Brush}" CornerRadius="6" Padding="12,8" Margin="48,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="FluentFTP" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="Robin Rodricks — MIT License" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="v53.0.2" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border Background="{ThemeResource SpanBgLayer2Brush}" CornerRadius="6" Padding="12,8" Margin="48,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="SSH.NET" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="Renci — MIT License" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="v2025.1.0" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Icon Fonts -->
                            <Border Style="{StaticResource SettingsCardBorder}">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE185;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <TextBlock Text="아이콘 폰트" Style="{StaticResource SettingsCardLabel}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Border Background="{ThemeResource SpanBgLayer2Brush}" CornerRadius="6" Padding="12,8" Margin="48,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Remix Icon" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="Remix Design — Apache 2.0 License" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="기본 아이콘 팩" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border Background="{ThemeResource SpanBgLayer2Brush}" CornerRadius="6" Padding="12,8" Margin="48,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Phosphor Icons" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="Phosphor Icons — MIT License" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="선택 가능" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <Border Background="{ThemeResource SpanBgLayer2Brush}" CornerRadius="6" Padding="12,8" Margin="48,0,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="Tabler Icons" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource SpanTextPrimaryBrush}" />
                                                <TextBlock Text="Tabler — MIT License" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="선택 가능" FontSize="11" Foreground="{ThemeResource SpanTextTertiaryBrush}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Full license link -->
                            <HyperlinkButton Style="{StaticResource LinkButtonStyle}" Margin="0,12,0,0"
                                             NavigateUri="https://github.com/kangjinkyu/Span/blob/main/LICENSES.md">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                    <TextBlock x:Name="FullLicenseLink" Text="View full license text on GitHub" />
                                </StackPanel>
                            </HyperlinkButton>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</UserControl>
