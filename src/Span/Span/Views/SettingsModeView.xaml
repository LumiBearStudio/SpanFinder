                                        <Border Style="{StaticResource CardIconContainer}">
                                            <FontIcon Glyph="&#xE7B3;" Style="{StaticResource CardIconStyle}" />
                                        </Border>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock x:Name="ViewOptionsLabel" Text="보기 옵션" Style="{StaticResource SettingsCardLabel}" />
                                            <TextBlock x:Name="ViewOptionsDesc" Text="파일 표시 관련 설정" Style="{StaticResource SettingsCardDesc}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Grid Margin="48,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                            <TextBlock x:Name="ShowHiddenLabel" Text="숨김 항목 표시" Style="{StaticResource ToggleRowLabel}" />
