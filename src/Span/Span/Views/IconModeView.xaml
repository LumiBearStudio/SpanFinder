<UserControl
    x:Class="Span.Views.IconModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Span.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Small Icon Template (16px) - Horizontal -->
        <DataTemplate x:Key="SmallIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="120" Height="28"
                  ToolTipService.ToolTip="{x:Bind Name, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0"
                          Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                          Foreground="{x:Bind IconBrush, Mode=OneWay}"
                          FontSize="16"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="{x:Bind Name, Mode=OneWay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           FontSize="13"/>
            </Grid>
        </DataTemplate>

        <!-- Medium Icon Template (48px) - Horizontal -->
        <DataTemplate x:Key="MediumIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="160" Height="56"
                  ToolTipService.ToolTip="{x:Bind Name, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0"
                          Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                          Foreground="{x:Bind IconBrush, Mode=OneWay}"
                          FontSize="48"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="{x:Bind Name, Mode=OneWay}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           FontSize="13"/>
            </Grid>
        </DataTemplate>

        <!-- Large Icon Template (96px) - Vertical -->
        <DataTemplate x:Key="LargeIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="120" Height="140"
                  ToolTipService.ToolTip="{x:Bind Name, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <FontIcon Grid.Row="0"
                          Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                          Foreground="{x:Bind IconBrush, Mode=OneWay}"
                          FontSize="96"
                          HorizontalAlignment="Center"
                          Margin="0,8,0,8"/>

                <TextBlock Grid.Row="1"
                           Text="{x:Bind Name, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           FontSize="13"
                           Margin="4,0"/>
            </Grid>
        </DataTemplate>

        <!-- Extra Large Icon Template (256px) - Vertical -->
        <DataTemplate x:Key="ExtraLargeIconTemplate" x:DataType="vm:FileSystemViewModel">
            <Grid Width="280" Height="320"
                  ToolTipService.ToolTip="{x:Bind Name, Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <FontIcon Grid.Row="0"
                          Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                          Foreground="{x:Bind IconBrush, Mode=OneWay}"
                          FontSize="256"
                          HorizontalAlignment="Center"
                          Margin="0,12,0,12"/>

                <TextBlock Grid.Row="1"
                           Text="{x:Bind Name, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap"
                           MaxLines="3"
                           FontSize="14"
                           Margin="8,0"/>
            </Grid>
        </DataTemplate>

        <!-- Horizontal Template Reference (used by code-behind) -->
        <DataTemplate x:Key="HorizontalIconTemplate" x:DataType="vm:FileSystemViewModel">
            <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource MediumIconTemplate}"/>
        </DataTemplate>

        <!-- Vertical Template Reference (used by code-behind) -->
        <DataTemplate x:Key="VerticalIconTemplate" x:DataType="vm:FileSystemViewModel">
            <ContentControl Content="{x:Bind}" ContentTemplate="{StaticResource LargeIconTemplate}"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <GridView
            x:Name="IconGridView"
            ItemsSource="{Binding CurrentItems, Mode=OneWay}"
            SelectedItem="{Binding CurrentFolder.SelectedChild, Mode=TwoWay}"
            SelectionMode="Extended"
            CanDragItems="True"
            AllowDrop="True"
            IsItemClickEnabled="True"
            ItemClick="OnItemClick"
            KeyDown="OnIconKeyDown"
            Padding="16">

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"
                                   HorizontalAlignment="Left"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <!-- Default to Medium Icon Template -->
            <GridView.ItemTemplate>
                <StaticResource ResourceKey="MediumIconTemplate"/>
            </GridView.ItemTemplate>

            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4"/>
                </Style>
            </GridView.ItemContainerStyle>
        </GridView>
    </Grid>
</UserControl>
