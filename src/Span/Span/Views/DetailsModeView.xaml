<UserControl
    x:Class="Span.Views.DetailsModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Span.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- No custom resources needed for ListView implementation -->
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <Grid Grid.Row="0" Height="20"
              Background="{ThemeResource SpanBgLayer2Brush}"
              BorderBrush="{ThemeResource SpanBorderSubtleBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*" MinWidth="180"/>
                <ColumnDefinition Width="200" MinWidth="140"/>
                <ColumnDefinition Width="150" MinWidth="90"/>
                <ColumnDefinition Width="100" MinWidth="80"/>
            </Grid.ColumnDefinitions>

            <!-- Icon Header (empty) -->

            <!-- Name Header -->
            <Button Grid.Column="1"
                    Content="Name"
                    Click="OnHeaderClick"
                    Tag="Name"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,0"
                    Height="20"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SpanTextSecondaryBrush}">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                </Button.Resources>
            </Button>

            <!-- Date Modified Header -->
            <Button Grid.Column="2"
                    Content="Date Modified"
                    Click="OnHeaderClick"
                    Tag="DateModified"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,0"
                    Height="20"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SpanTextSecondaryBrush}">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                </Button.Resources>
            </Button>

            <!-- Type Header -->
            <Button Grid.Column="3"
                    Content="Type"
                    Click="OnHeaderClick"
                    Tag="Type"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,0"
                    Height="20"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SpanTextSecondaryBrush}">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                </Button.Resources>
            </Button>

            <!-- Size Header -->
            <Button Grid.Column="4"
                    Content="Size"
                    Click="OnHeaderClick"
                    Tag="Size"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,0"
                    Height="20"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SpanTextSecondaryBrush}">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Items List -->
        <ListView Grid.Row="1"
                  x:Name="DetailsListView"
                  ItemsSource="{Binding CurrentItems, Mode=OneWay}"
                  SelectedItem="{Binding CurrentFolder.SelectedChild, Mode=TwoWay}"
                  SelectionMode="Extended"
                  DoubleTapped="OnItemDoubleClick"
                  KeyDown="OnDetailsKeyDown"
                  Background="Transparent"
                  Padding="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinHeight" Value="18"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileSystemViewModel">
                    <Grid Height="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*" MinWidth="180"/>
                            <ColumnDefinition Width="200" MinWidth="140"/>
                            <ColumnDefinition Width="150" MinWidth="90"/>
                            <ColumnDefinition Width="100" MinWidth="80"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <FontIcon Grid.Column="0"
                                  FontFamily="{StaticResource RemixIcons}"
                                  Glyph="{x:Bind IconGlyph, Mode=OneWay}"
                                  Foreground="{x:Bind IconBrush, Mode=OneWay}"
                                  FontSize="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                        <!-- Name -->
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Name, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="11"
                                   Padding="6,0"/>

                        <!-- Date Modified -->
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind DateModified, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Padding="6,0"/>

                        <!-- Type -->
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind FileType, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Padding="6,0"/>

                        <!-- Size -->
                        <TextBlock Grid.Column="4"
                                   Text="{x:Bind Size, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Padding="6,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
